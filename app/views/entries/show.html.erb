<% if current_user != nil && @entry["user_id"] == current_user["id"] %>
  <div class="mb-4">
    <h1 class="mb-1"><%= @entry["title"] %></h1>
    <p class="text-muted"><%= @entry["occurred_on"] %></p>

    <% if @entry.image.attached? %>
      <img src="<%= url_for(@entry.image) %>" class="img-fluid rounded mb-3" alt="<%= @entry["title"] %>">
    <% end %>

    <p><%= @entry["description"] %></p>
  </div>

  <a href="/places/<%= @place["id"] %>" class="btn btn-secondary">Back to <%= @place["name"] %></a>
<% else %>
  <p>Entry not found or you do not have permission to view it.</p>
  <a href="/places" class="btn btn-secondary">Back to Places</a>
<% end %>
