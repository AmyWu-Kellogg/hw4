<h1 class="mb-4">Entries for <%= @place["name"] %></h1>

<div class="row">
  <% for entry in @entries %>
    <div class="col-lg-4 col-md-6 mb-4">
      <div class="card h-100">
        <% if entry.image.attached? %>
          <img src="<%= url_for(entry.image) %>" class="card-img-top" alt="<%= entry["title"] %>">
        <% end %>
        <div class="card-body">
          <h5 class="card-title"><%= entry["title"] %></h5>
          <h6 class="card-subtitle mb-2 text-muted"><%= entry["occurred_on"] %></h6>
          <p class="card-text"><%= entry["description"] %></p>
          <a href="/places/<%= @place["id"] %>/entries/<%= entry["id"] %>" class="btn btn-sm btn-outline-primary">View</a>
        </div>
      </div>
    </div>
  <% end %>
</div>

<a href="/places/<%= @place["id"] %>/entries/new" class="btn btn-primary">New Entry</a>
<a href="/places/<%= @place["id"] %>" class="btn btn-secondary ms-2">Back to Place</a>
