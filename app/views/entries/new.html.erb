<h1 class="mb-4">New Entry</h1>

<% if current_user != nil %>
  <form action="/places/<%= @place["id"] %>/entries" method="post" enctype="multipart/form-data">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

    <div class="mb-3">
      <label for="title_input" class="form-label">Title</label>
      <input type="text" name="title" id="title_input" class="form-control">
    </div>

    <div class="mb-3">
      <label for="description_input" class="form-label">Description</label>
      <textarea name="description" id="description_input" class="form-control" rows="4"></textarea>
    </div>

    <div class="mb-3">
      <label for="occurred_on_input" class="form-label">Occurred On</label>
      <input type="date" name="occurred_on" id="occurred_on_input" class="form-control">
    </div>

    <div class="mb-3">
      <label for="image_input" class="form-label">Photo (optional)</label>
      <input type="file" name="image" id="image_input" class="form-control" accept="image/*">
    </div>

    <button class="btn btn-primary">Save Entry</button>
    <a href="/places/<%= @place["id"] %>" class="btn btn-secondary ms-2">Cancel</a>
  </form>
<% else %>
  <p>Please <a href="/session/new">log in</a> to create an entry.</p>
<% end %>