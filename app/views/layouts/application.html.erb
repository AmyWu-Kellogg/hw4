<!DOCTYPE html>
<html>
  <head>
    <title>Tacostagram Final</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="stylesheet" href="/stylesheets/application.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <a class="navbar-brand" href="/">Travel Journal</a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/">Home</a>
          <% if current_user != nil %>
            <span class="nav-link text-light"><%= current_user["username"] %></span>
            <form action="/session" method="post" class="d-inline">
              <%= hidden_field_tag :_method, "delete" %>
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <button type="submit" class="btn btn-outline-light btn-sm ms-2">Logout</button>
            </form>
          <% else %>
            <a class="nav-link" href="/session/new">Login</a>
            <a class="nav-link" href="/users/new">Signup</a>
          <% end %>
        </div>
      </div>
    </nav>

    <% if flash["notice"] %>
      <div class="container">
        <div class="alert alert-info"><%= flash["notice"] %></div>
      </div>
    <% end %>

    <div class="container">
      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
